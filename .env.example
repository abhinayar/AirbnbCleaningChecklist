# ---- Database (Railway provides this automatically when you add a Postgres plugin) ----
DATABASE_URL="postgresql://user:password@host:5432/railway"

# ---- Claude vision (https://console.anthropic.com) ----
ANTHROPIC_API_KEY="sk-ant-..."
# Vision model for blur + QC checks. Opus 4.8 is the most accurate; set to
# claude-sonnet-4-6 if you want lower cost per photo.
QC_MODEL="claude-opus-4-8"

# ---- Email delivery (https://resend.com) ----
RESEND_API_KEY="re_..."
# Must be a verified sender on your Resend account. Resend's onboarding domain works to start:
RESEND_FROM="Cleaning QC <onboarding@resend.dev>"
# Default report recipients (comma-separated). Can also be edited in the admin UI.
REPORT_RECIPIENTS="owner@example.com,manager@example.com,records@example.com"

# ---- Admin access ----
# Password to open the /admin dashboard.
ADMIN_PASSWORD="change-me"
# Random string used to sign the admin session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# ---- App ----
# Public base URL of the deployment (used in emails/links). Optional.
APP_URL="https://your-app.up.railway.app"
